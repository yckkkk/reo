  "font": {
    "waldenburg": {
      "$value": "Waldenburg",
      "$type": "fontFamily",
      "$description": "All display and section headlines. Weight 300, tight line-height, and negative tracking create Reo's restrained heading style."
    },
    "waldenburgfh": {
      "$value": "WaldenburgFH",
      "$type": "fontFamily",
      "$description": "Navigation product labels and icon badges. The 0.05em wide tracking at weight 700 creates a compressed, stamp-like label style — tight caps energy in a small footprint."
    },
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "All body copy, UI labels, navigation, buttons, captions, footer. Weight 400 for body and descriptive text; weight 500 for interactive labels and emphasis. The 0.01em letter-spacing is a subtle open tracking that keeps small sizes legible on eggshell."
    },
    "geist-mono": {
