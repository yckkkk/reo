{
  "color": {
    "eggshell": {
      "$value": "#fdfcfc",
      "$type": "color",
      "$description": "Eggshell — Page background and primary surface — the near-white warmth distinguishes this from pure #ffffff, landing type with extra weight"
    },
    "powder": {
      "$value": "#f5f3f1",
      "$type": "color",
      "$description": "Powder — Secondary surface, hover states, subtle section backgrounds"
    },
    "chalk": {
      "$value": "#e5e5e5",
      "$type": "color",
      "$description": "Chalk — All borders, dividers, card outlines, button outlines — the single border color used universally"
    },
    "fog": {
      "$value": "#b1b0b0",
      "$type": "color",
      "$description": "Fog — Disabled states, placeholder elements, logo grid grayscale treatment"
    },
    "gravel": {
      "$value": "#777169",
      "$type": "color",
      "$description": "Gravel — Secondary body text, nav items, subheadings, captions — warm stone undertone separates it from a cold gray"
    },
    "slate": {
      "$value": "#a59f97",
      "$type": "color",
      "$description": "Slate — Tertiary text, icon strokes, deemphasized labels"
    },
    "cinder": {
      "$value": "#57534f",
      "$type": "color",
      "$description": "Cinder — Mid-tone text, secondary headings on light surfaces"
    },
    "obsidian": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Obsidian — Primary text, filled action background, logo mark — the absolute black against eggshell creates 20.5:1 contrast"
    },
    "signal-blue": {
      "$value": "#0447ff",
      "$type": "color",
      "$description": "Signal Blue — Reo accent — appears only in small circular UI elements, not in text or pill buttons"
    },
    "ember": {
      "$value": "#ff4704",
      "$type": "color",
      "$description": "Ember — Secondary Reo avatar accent — small circular UI indicator only"
    },
    "voice-spectrum": {
