{
  "name": "reo",
  "private": true,
  "version": "0.1.0",
  "description": "Reo Electron app",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "main": "./out/main/index.js",
  "scripts": {
    "start": "electron-vite preview --ignoreConfigWarning",
    "dev": "node scripts/run-dev.mjs",
    "build": "npm run typecheck && npm run build:app",
    "build:app": "electron-vite build --ignoreConfigWarning",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.main.json --noEmit",
    "typecheck:quick": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.electron-vite.json --noEmit",
    "test:main": "node scripts/run-main-tests.mjs",
    "test:renderer": "node scripts/run-renderer-tests.mjs",
    "complexity:scan": "node scripts/run-complexity-scan.mjs",
    "lint": "eslint .",
    "lint:strict": "eslint . --max-warnings=0",
    "format:check": "prettier --check AGENTS.md .claude/CLAUDE.md README.md package.json package-lock.json components.json electron.vite.config.ts vitest.config.ts tsconfig*.json eslint.config.js scripts src test docs/README.md docs/current docs/decisions docs/initiatives && prettier --check --no-error-on-unmatched-pattern docs/specs",
    "format:check:all": "prettier --check .",
    "verify:quick": "npm run typecheck:quick && npm run test:main && npm run test:renderer && npm run lint:strict && npm run format:check",
    "verify:strict": "npm run typecheck && npm run test:main && npm run test:renderer && npm run lint:strict && npm run format:check && npm run build:app",
    "verify:titlebar": "node scripts/measure-titlebar-alignment.mjs",
    "verify:titlebar:self-test": "node scripts/measure-titlebar-alignment.mjs --self-test",
    "verify:memory-studio-layout": "node scripts/measure-memory-studio-layout.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@floating-ui/react": "^0.27.19",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.100.9",
    "@tiptap/core": "^3.23.6",
    "@tiptap/extension-heading": "^3.23.6",
    "@tiptap/extension-highlight": "^3.23.6",
    "@tiptap/extension-horizontal-rule": "^3.23.6",
    "@tiptap/extension-image": "^3.23.6",
    "@tiptap/extension-list": "^3.23.6",
    "@tiptap/extension-paragraph": "^3.23.6",
    "@tiptap/extension-subscript": "^3.23.6",
    "@tiptap/extension-superscript": "^3.23.6",
    "@tiptap/extension-text-align": "^3.23.6",
    "@tiptap/extension-typography": "^3.23.6",
    "@tiptap/extensions": "^3.23.6",
    "@tiptap/markdown": "^3.23.6",
    "@tiptap/pm": "^3.23.6",
    "@tiptap/react": "^3.23.6",
    "@tiptap/starter-kit": "^3.23.6",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "electron-log": "^5.4.4",
    "gray-matter": "^4.0.3",
    "lodash.throttle": "^4.1.1",
    "lucide-react": "^1.14.0",
    "primereact": "^10.9.7",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.75.0",
    "react-hotkeys-hook": "^5.3.2",
    "sass-embedded": "^1.100.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "vaul": "^1.1.2",
    "ws": "^8.20.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/lodash.throttle": "^4.1.9",
    "@types/node": "^22.18.11",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "agentation": "^3.0.2",
    "electron": "^41.5.0",
    "electron-vite": "6.0.0-beta.1",
    "eslint": "^10.2.0",
    "globals": "^17.3.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.7.4",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
